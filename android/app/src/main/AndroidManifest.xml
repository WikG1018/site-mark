<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Security boundary: SiteMark is a fully offline app. No ads, analytics,
         accounts, cloud sync, remote APIs, Google Play Services, or network
         access of any kind. The workmanager_android plugin (Task 3) pulls in
         androidx.work:work-runtime, whose manifest declares ACCESS_NETWORK_STATE,
         and the debug/profile build variants declare INTERNET for Flutter dev
         tools. We strip both at manifest-merge time so they never reach the
         shipped APK, even in debug builds. WAKE_LOCK, RECEIVE_BOOT_COMPLETED,
         and FOREGROUND_SERVICE are kept because WorkManager uses them for local
         on-device background processing and boot reconciliation, none of which
         grants network access. -->
    <uses-permission android:name="android.permission.INTERNET" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" tools:node="remove" />

    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Local completion notifications: the app posts a "photo ready" local
         notification when background rendering finishes. The runtime
         permission is requested on Android 13+ only after the user enables
         the setting; notifications are local-only, matching the offline
         security boundary above. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_name"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:enableOnBackInvokedCallback="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- ITGSA (金标联盟) "fair running memory" receivers.
             Registered statically so they fire even when the app process is
             in the background. On non-ITGSA ROMs the intents are never
             broadcast, so the receivers add zero overhead.

             `exported="true"` is required because ITGSA broadcasts may be
             sent by the OEM's "phone manager" / memory-management service,
             which may not run under the system_server UID. A non-exported
             receiver only accepts broadcasts from the same UID or system
             UID, which would silently drop the pressure event. The ITGSA
             action strings are vendor-specific and not triggered by normal
             Android system events, so the exposure is limited to a
             malicious app deliberately sending ITGSA actions — the
             receiver's response (releasing caches, persisting drafts) is
             benign and has no data-exfiltration risk.

             REAL-DEVICE VERIFICATION (required before claiming ITGSA
             compliance):
               1. Install the app on the target ITGSA ROM device.
               2. Put the app in the background and trigger the OEM's
                  memory-pressure mechanism (e.g. via the phone manager's
                  "clean memory" feature, or by loading enough apps to
                  trigger automatic trimming).
               3. Check logcat for:
                  - "MemoryPressureReceiver: Received <action>" — confirms
                    the broadcast was delivered.
                  - "MemoryPressureReceiver: Binder found via key '<key>'" —
                    confirms the Binder extra key is readable.
                  - "MemoryPressurePlugin: Dart handler" / "acknowledge" —
                    confirms the Dart side processed and ACKed.
                  - Absence of "acknowledge failed" — confirms the ACK
                    transact succeeded.
               4. If the broadcast is NOT received, the ROM may use a
                  different action string or delivery mechanism. Consult the
                  vendor's ITGSA developer documentation and update
                  ACTION_MEMORY_TRIM / ACTION_MEMORY_KILL accordingly.
               5. If the Binder is NOT found, add the vendor's extra key to
                  the `keys` list in MemoryPressureReceiver.pickCallbackBinder.
             -->
        <receiver
            android:name=".memory.MemoryPressureReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="itgsa.intent.action.MEMORY_TRIM" />
                <action android:name="itgsa.intent.action.MEMORY_KILL" />
            </intent-filter>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
